        AutoSellPriceTarget = Value
    end,
})

local GasPriceLabel = GameTab:CreateLabel("Current GasPrice: loading...", 4483362458, Color3.fromRGB(255, 255, 255), false)
local PlotStatusLabel = GameTab:CreateLabel("Owned Plot: scanning...", 4483362458, Color3.fromRGB(255, 255, 255), false)
local InstantStealStatusLabel = GameTab:CreateLabel("Instant Steal: Off", 4483362458, Color3.fromRGB(255, 255, 255), false)
local BestRefineryStatusLabel = GameTab:CreateLabel("Best Refinery: scanning...", 4483362458, Color3.fromRGB(255, 255, 255), false)

local function updateGasPriceLabel()
    local numeric = getNumericGasPrice()
    if numeric then
        GasPriceLabel:Set("Current GasPrice: $" .. tostring(numeric), 4483362458, Color3.fromRGB(255, 255, 255), false)
    else
        GasPriceLabel:Set("Current GasPrice: " .. tostring(GasPriceValue.Value), 4483362458, Color3.fromRGB(255, 255, 255), false)
    end
end

local function updateOwnedPlotLabel()
    local ownedPlot = findOwnedPlot()

    if ownedPlot then
        PlotStatusLabel:Set(
            "Owned Plot: " .. ownedPlot.Name,
            4483362458,
            Color3.fromRGB(255, 255, 255),
            false
        )
    else
        PlotStatusLabel:Set(
            "Owned Plot: not found",
            4483362458,
            Color3.fromRGB(255, 255, 255),
            false
        )
    end
end

local function updateInstantStealStatusLabel()
    local count = 0
    for _ in pairs(OriginalStealDurations) do
        count = count + 1
    end

    if InstantStealEnabled then
        InstantStealStatusLabel:Set("Instant Steal: On (" .. tostring(count) .. " prompts)", 4483362458, Color3.fromRGB(255, 255, 255), false)
    else
        InstantStealStatusLabel:Set("Instant Steal: Off", 4483362458, Color3.fromRGB(255, 255, 255), false)
    end
end

local function updateBestRefineryStatusLabel()
    local bestBuilding, _, bestPlot, bestCurrent, bestMax, bestRawText = getBestRefinery()

    if bestBuilding and bestPlot and bestMax then
        BestRefineryStatusLabel:Set(
            "Best Refinery: " .. bestPlot.Name .. " | " .. bestBuilding.Name .. " | " .. tostring(bestRawText or (tostring(bestCurrent) .. "/" .. tostring(bestMax))),
            4483362458,
            Color3.fromRGB(255, 255, 255),
            false
        )
    else
        BestRefineryStatusLabel:Set(
            "Best Refinery: not found",
            4483362458,
            Color3.fromRGB(255, 255, 255),
            false
        )
    end
end

updateGasPriceLabel()
updateOwnedPlotLabel()
refreshInstantSteal()
bindAllStealPrompts()
updateInstantStealStatusLabel()
updateBestRefineryStatusLabel()

GasPriceValue:GetPropertyChangedSignal("Value"):Connect(updateGasPriceLabel)

for i = 1, 6 do
    local plot = PlotsFolder:FindFirstChild("Plot" .. i)
    if plot then
        plot.DescendantAdded:Connect(function(descendant)
            task.defer(updateOwnedPlotLabel)
            task.defer(updateBestRefineryStatusLabel)

            if descendant:IsA("ProximityPrompt") and descendant.Name == "Steal" then
                if OriginalStealDurations[descendant] == nil then
                    OriginalStealDurations[descendant] = descendant.HoldDuration
                end

                bindStealPrompt(descendant)

                if InstantStealEnabled then
                    setStealPromptHoldDuration(descendant, 0)
                end

                task.defer(updateInstantStealStatusLabel)
            end
        end)

        plot.DescendantRemoving:Connect(function(descendant)
            if descendant:IsA("ProximityPrompt") and descendant.Name == "Steal" then
                OriginalStealDurations[descendant] = nil
                unbindStealPrompt(descendant)
                task.defer(updateInstantStealStatusLabel)
            end

            task.defer(updateOwnedPlotLabel)
            task.defer(updateBestRefineryStatusLabel)
        end)
    end
end

GameTab:CreateSection("Auto Collect Gas")

GameTab:CreateToggle({
    Name = "Auto Collect Gas",
    CurrentValue = false,
    Flag = "AutoCollectGasToggle",
    Callback = function(Value)
        AutoCollectGasEnabled = Value

        if Value then
            startAutoCollectLoop()
        else
            AutoCollectLoopId = AutoCollectLoopId + 1
        end
    end,
})

GameTab:CreateSection("Steal")

GameTab:CreateToggle({
    Name = "Instant Steal",
    CurrentValue = false,
    Flag = "InstantStealToggle",
    Callback = function(Value)
        InstantStealEnabled = Value
        refreshInstantSteal()
        updateInstantStealStatusLabel()
    end,
})

GameTab:CreateToggle({
    Name = "Auto Return After Steal",
    CurrentValue = true,
    Flag = "AutoReturnAfterStealToggle",
    Callback = function(Value)
        AutoReturnAfterStealEnabled = Value
    end,
})

GameTab:CreateButton({
    Name = "Return To Random Base Building",
    Callback = function()
        returnToOwnedBase()
    end,
})

GameTab:CreateSection("Best Refinery ESP")

GameTab:CreateToggle({
    Name = "Show Best Refinery Line",
    CurrentValue = false,
    Flag = "BestRefineryESPToggle",
    Callback = function(Value)
        BestRefineryESPEnabled = Value

        if Value then
            startBestRefineryESP()
            updateBestRefineryStatusLabel()
        else
            stopBestRefineryESP()
        end
    end,
})

GameTab:CreateButton({
    Name = "Refresh Owned Plot Check",
    Callback = function()
        updateOwnedPlotLabel()
    end,
})

GameTab:CreateButton({
    Name = "Refresh Instant Steal",
    Callback = function()
        refreshInstantSteal()
        updateInstantStealStatusLabel()
    end,
})

GameTab:CreateButton({
    Name = "Refresh Best Refinery",
    Callback = function()
        updateBestRefineryStatusLabel()
        updateBestRefineryESP()
    end,
})

--// =========================================================
--// Drills Tab
--// =========================================================

DrillsTab:CreateSection("Drills")

DrillsTab:CreateSlider({
    Name = "Purchase Delay",
    Range = {1, 20},
    Increment = 1,
    CurrentValue = 2,
    Flag = "DrillPurchaseDelaySlider",
    Callback = function(Value)
        DrillPurchaseDelay = Value / 100
    end,
})

for _, drillName in ipairs(DrillNames) do
    DrillPurchaseEnabled[drillName] = false
    DrillPurchaseLoopIds[drillName] = 0

    DrillsTab:CreateToggle({
        Name = drillName,
        CurrentValue = false,
        Flag = "DrillToggle_" .. drillName:gsub("%s+", "_"),
        Callback = function(Value)
            if Value then
                startDrillPurchaseLoop(drillName)
            else
                stopDrillPurchaseLoop(drillName)
            end
        end,
    })
end

